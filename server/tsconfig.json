{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["@types/bun"],
    "baseUrl": ".",
    "paths": {
      "@4tori/shared": ["../shared/src"],
      "@4tori/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "../shared/src"]
}
